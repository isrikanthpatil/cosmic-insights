# =============================================================================
# Environment variables for the self-hosted Astrology backend.
# Copy to .env (in the cloned supabase/docker directory) and fill in real
# values. NEVER commit the real .env. Most of these are consumed by the
# official Supabase self-hosting compose; DOMAIN and OLLAMA_MODEL are ours.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# Password for the Postgres "postgres"/"supabase_admin" superuser.
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=replace-with-strong-random-password

# --- JWT / API keys -----------------------------------------------------------
# JWT_SECRET signs all Supabase JWTs. ANON_KEY and SERVICE_ROLE_KEY are JWTs
# signed with JWT_SECRET. Generate all three with Supabase's helper:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# (or the JWT generator at https://supabase.com/docs/guides/self-hosting/docker)
# JWT_SECRET must be >= 32 chars:  openssl rand -hex 32
JWT_SECRET=replace-with-32-plus-char-random-secret
ANON_KEY=replace-with-generated-anon-jwt
SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt

# --- URLs ---------------------------------------------------------------------
# Public site URL (used for auth redirects / email links). Your https domain
# or the droplet IP. Must match what the Expo app points at.
SITE_URL=https://your-domain.com

# --- Our overlay (Caddy + Ollama) ---------------------------------------------
# Domain Caddy serves and provisions TLS for. Set a DNS A record -> droplet IP.
DOMAIN=your-domain.com

# Ollama model pulled after startup (docker exec ollama ollama pull $OLLAMA_MODEL).
# 3b fits a resized/8GB+ droplet; see the RAM callout in DEPLOYMENT.md.
OLLAMA_MODEL=llama3.2:3b
